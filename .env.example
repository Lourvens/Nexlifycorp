# NexlifyCorp Environment Configuration
# Copy to .env and fill in values

# =============================================================================
# ANTHROPIC / CLAUDE
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4.6

# =============================================================================
# LANGCHAIN / LANGSMITH (Optional - for tracing)
# =============================================================================
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_TRACING=true
LANGCHAIN_PROJECT=nexlifycorp

# =============================================================================
# LANGGRAPH
# =============================================================================
LANGGRAPH_URL=http://localhost:8000

# =============================================================================
# QDRANT VECTOR STORE
# =============================================================================
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=nexlify_kb

# =============================================================================
# EMBEDDINGS
# =============================================================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# =============================================================================
# SEC EDGAR
# =============================================================================
SEC_EDGAR_COMPANY_NAME="Nexlify Corp Learning"
SEC_EDGAR_EMAIL="nexlify-learning@example.com"
